","            return \"0–1 - normalize\"\n","        else:\n","            return f\"{min}-{max} -> consider scaling\"\n","    else:\n","        return \"non-numeric -> consider encoding\"\n","        print('value range classification:')\n","df.apply(classify_ranges)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":586},"id":"LdTALeAOH1Ph","executionInfo":{"status":"ok","timestamp":1748261166562,"user_tz":-330,"elapsed":27,"user":{"displayName":"Durgesh Kumar Dewangan","userId":"00590463210778196862"}},"outputId":"f3c6fa7d-0d60-482d-b393-c086016e2043"},"execution_count":13,"outputs":[{"output_type":"execute_result","data":{"text/plain":["year                       2015-2022 -> consider scaling\n","gender                  non-numeric -> consider encoding\n","age                        0.08-80.0 -> consider scaling\n","location                non-numeric -> consider encoding\n","race_AfricanAmerican                     0–1 - normalize\n","race_Asian                               0–1 - normalize\n","race_Caucasian                           0–1 - normalize\n","race_Hispanic                            0–1 - normalize\n","race_Other                               0–1 - normalize\n","hypertension                             0–1 - normalize\n","heart_disease                            0–1 - normalize\n","smoking_history         non-numeric -> consider encoding\n","bmi                      10.01-95.69 -> consider scaling\n","hbA1c_level                  3.5-9.0 -> consider scaling\n","blood_glucose_level           80-300 -> consider scaling\n","diabetes                                 0–1 - normalize\n","dtype: object"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"datafram